                                                                        @section Scripts {
                                                                            <script>
                                                                                // ГўвҖқвӮ¬ГўвҖқвӮ¬ Datos del servidor ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬
                                                                                const pacientes = @Html.Raw(pacientesJson);
                                                                                const hombres = pacientes.filter(p => p.genero === 'M');
                                                                                const mujeres = pacientes.filter(p => p.genero === 'F');
                                                                                const promedioG = @Model.PromedioGeneralPeso.ToString("F4", inv);
                                                                                const promedioH = @Model.PromedioHombresPeso.ToString("F4", inv);
                                                                                const promedioM = @Model.PromedioMujeresPeso.ToString("F4", inv);
                                                                                const diffMedias = @Model.DiferenciaMedias.ToString("F4", inv);
                                                                                const se = @Model.ErrorEstandar.ToString("F4", inv);
                                                                                const icLow = @Model.ICLimiteInferior.ToString("F4", inv);
                                                                                const icHigh = @Model.ICLimiteSuperior.ToString("F4", inv);
                                                                                const tStat = @Model.TEstadistico.ToString("F4", inv);
                                                                                const tCritHip = @Model.TCriticoHipotesis.ToString("F4", inv);
                                                                                const nu = @(Model.NTotal - 1);
                                                                                const pValor = @Model.ValorP.ToString("F6", inv);
                                                                                const rechazaH0 = @(Model.RechazaH0 ? "true" : "false");
                                                                                const ncPct = '@((Model.NivelConfianza * 100).ToString("F1"))';

                                                                                // ГўвҖқвӮ¬ГўвҖқвӮ¬ Paleta United / Bootswatch ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬
                                                                                const C_ORANGE = 'rgba(233,84,32,0.85)';
                                                                                const C_BLUE = 'rgba(55,101,167,0.85)';
                                                                                const C_GREEN = 'rgba(56,180,74,0.85)';
                                                                                const C_RED = 'rgba(223,56,44,0.85)';
                                                                                const C_YELLOW = 'rgba(239,183,62,0.85)';
                                                                                const C_GREY = 'rgba(108,117,125,0.7)';

                                                                                // ГўвҖқвӮ¬ГўвҖқвӮ¬ Sync sliders <-> inputs ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬
                                                                                function syncParam(key, rawVal) {
                                                                                    const v = parseFloat(rawVal);
                                                                                    if (isNaN(v)) return;
                                                                                    const rng = document.getElementById('rng' + key);
                                                                                    const num = document.getElementById('num' + key);
                                                                                    if (document.activeElement === rng) num.value = rawVal;
                                                                                    else rng.value = v;
                                                                                }

                                                                                // ГўвҖқвӮ¬ГўвҖқвӮ¬ Gamma / t-PDF helpers ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬ГўвҖқвӮ¬
                                                                                function lnGamma(x) {
                                                                                    const g = [76.18009172947146, -86.50532032941677, 24.01409824083091,
                                                                                        -1.231739572450155, 1.208650973866179e-3, -5.395239384953e-6];
                                                                                    let y = x, tmp = x + 5.5; tmp -= (x + 0.5) * Math.log(tmp);
                                                                                    let ser = 1.000000000190015; g.forEach(c => { ser += c / ++y; });
                                                                                    return -tmp + Math.log(2.5066282746310005 * ser / x);
                                                                                }
                                                                                function tPDF(t, nu) {
                                                                                    return Math.exp(lnGamma((nu + 1) / 2) - lnGamma(nu / 2)
                                                                                        - 0.5 * Math.log(nu * Math.PI) - (nu + 1) / 2 * Math.log(1 + t * t / nu));
                                                                                }

                                                                                // ГўвҖўВҗГўвҖўВҗ GRAFICA a1: Barras de promedios ГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗ
                                                                                new Chart(document.getElementById('chartPromedios'), {
                                                                                    type: 'bar',
                                                                                    data: {
                                                                                        labels: ['General', 'Hombres', 'Mujeres'],
                                                                                        datasets: [{
                                                                                            label: 'Promedio de Peso (kg)',
                                                                                            data: [promedioG, promedioH, promedioM],
                                                                                            backgroundColor: [C_GREY, C_ORANGE, C_BLUE],
                                                                                            borderColor: ['#6c757d', '#e95420', '#3765a7'],
                                                                                            borderWidth: 2, borderRadius: 8
                                                                                        }]
                                                                                    },
                                                                                    options: {
                                                                                        responsive: true,
                                                                                        plugins: {
                                                                                            legend: { display: false },
                                                                                            tooltip: { callbacks: { label: ctx => ` ${ctx.raw.toFixed(2)} kg` } }
                                                                                        },
                                                                                        scales: { y: { beginAtZero: false, min: 50, title: { display: true, text: 'kg' } } }
                                                                                    }
                                                                                });

                                                                                // ГўвҖўВҗГўвҖўВҗ GRAFICA a2: Dispersion individual pesos ГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗ
                                                                                new Chart(document.getElementById('chartPesos'), {
                                                                                    type: 'scatter',
                                                                                    data: {
                                                                                        datasets: [
                                                                                            {
                                                                                                label: 'Hombres',
                                                                                                data: hombres.map((p, i) => ({ x: i + 1, y: Number(p.pesoKg) })),
                                                                                                backgroundColor: C_ORANGE, pointRadius: 8, pointHoverRadius: 10
                                                                                            },
                                                                                            {
                                                                                                label: 'Mujeres',
                                                                                                data: mujeres.map((p, i) => ({ x: i + 1, y: Number(p.pesoKg) })),
                                                                                                backgroundColor: C_BLUE, pointRadius: 8, pointHoverRadius: 10
                                                                                            },
                                                                                            {
                                                                                                label: `x\u0305 = ${Number(promedioG).toFixed(2)} kg`,
                                                                                                data: [{ x: 0, y: promedioG }, { x: Math.max(hombres.length, mujeres.length) + 1, y: promedioG }],
                                                                                                type: 'line', borderColor: C_GREEN, borderWidth: 2,
                                                                                                borderDash: [6, 4], pointRadius: 0, fill: false
                                                                                            }
                                                                                        ]
                                                                                    },
                                                                                    options: {
                                                                                        responsive: true,
                                                                                        plugins: {
                                                                                            tooltip: {
                                                                                                callbacks: {
                                                                                                    label: ctx => {
                                                                                                        if (ctx.datasetIndex < 2) {
                                                                                                            const arr = ctx.datasetIndex === 0 ? hombres : mujeres;
                                                                                                            return ` ${arr[ctx.dataIndex].nombre}: ${ctx.raw.y} kg`;
                                                                                                        }
                                                                                                        return ` ${ctx.dataset.label}`;
                                                                                                    }
                                                                                                }
                                                                                            }
                                                                                        },
                                                                                        scales: {
                                                                                            x: { title: { display: true, text: 'Paciente #' } },
                                                                                            y: { title: { display: true, text: 'Peso (kg)' } }
                                                                                        }
                                                                                    }
                                                                                });

                                                                                // ГўвҖўВҗГўвҖўВҗ GRAFICA b: IC horizontal ГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗ
                                                                                new Chart(document.getElementById('chartIC'), {
                                                                                    type: 'bar',
                                                                                    data: {
                                                                                        labels: [`IC ${ncPct}%`],
                                                                                        datasets: [
                                                                                            { label: `L. Inferior: ${icLow}`, data: [icLow], backgroundColor: 'rgba(233,84,32,0.18)', borderColor: C_ORANGE, borderWidth: 2 },
                                                                                            { label: `Diferencia:  ${diffMedias}`, data: [diffMedias], backgroundColor: C_ORANGE, borderColor: C_ORANGE, borderWidth: 3 },
                                                                                            { label: `L. Superior: ${icHigh}`, data: [icHigh], backgroundColor: 'rgba(233,84,32,0.18)', borderColor: C_ORANGE, borderWidth: 2 }
                                                                                        ]
                                                                                    },
                                                                                    options: {
                                                                                        indexAxis: 'y',
                                                                                        responsive: true,
                                                                                        plugins: {
                                                                                            title: { display: true, text: `IC ${ncPct}% \u2014 Diferencia de Medias (Hombres \u2212 Mujeres)`, font: { size: 13 } },
                                                                                            tooltip: { callbacks: { label: ctx => ` ${Number(ctx.raw).toFixed(4)} kg` } }
                                                                                        },
                                                                                        scales: { x: { title: { display: true, text: 'Diferencia (kg)' } } }
                                                                                    }
                                                                                });

                                                                                // ГўвҖўВҗГўвҖўВҗ GRAFICA c: Curva t con zona de rechazo ГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗ
                                                                                const xT = Array.from({ length: 400 }, (_, i) => -4.5 + 9 * i / 399);
                                                                                const yT = xT.map(t => tPDF(t, nu));
                                                                                const clrBar = xT.map(t => t < tCritHip ? 'rgba(223,56,44,0.55)' : 'rgba(55,101,167,0.18)');

                                                                                new Chart(document.getElementById('chartHipotesis'), {
                                                                                    type: 'bar',
                                                                                    data: {
                                                                                        labels: xT.map(t => t.toFixed(2)),
                                                                                        datasets: [
                                                                                            {
                                                                                                label: 'f(t)',
                                                                                                data: yT,
                                                                                                backgroundColor: clrBar,
                                                                                                borderColor: 'transparent',
                                                                                                barPercentage: 1.0, categoryPercentage: 1.0
                                                                                            },
                                                                                            {
                                                                                                type: 'line',
                                                                                                label: `t obs = ${tStat}`,
                                                                                                data: xT.map((t, i) => Math.abs(t - tStat) < 9 / 399 * 2 ? yT[i] * 1.15 : null),
                                                                                                borderColor: rechazaH0 ? '#df382c' : '#efb73e',
                                                                                                borderWidth: 3, pointRadius: 0, fill: false
                                                                                            },
                                                                                            {
                                                                                                type: 'line',
                                                                                                label: `t crit = ${tCritHip}`,
                                                                                                data: xT.map((t, i) => Math.abs(t - tCritHip) < 9 / 399 * 2 ? yT[i] * 1.15 : null),
                                                                                                borderColor: '#333', borderWidth: 2,
                                                                                                borderDash: [5, 5], pointRadius: 0, fill: false
                                                                                            }
                                                                                        ]
                                                                                    },
                                                                                    options: {
                                                                                        responsive: true,
                                                                                        plugins: {
                                                                                            title: {
                                                                                                display: true,
                                                                                                text: `t(\u03bd=${nu})  |  t_obs=${tStat}  |  t_crit=${tCritHip}  |  p=${pValor}`,
                                                                                                font: { size: 13 }
                                                                                            },
                                                                                            legend: { position: 'bottom' },
                                                                                            tooltip: { enabled: false }
                                                                                        },
                                                                                        scales: {
                                                                                            x: { ticks: { maxTicksLimit: 10, callback: (_, i) => Number(xT[i]).toFixed(1) }, title: { display: true, text: 'Valor t' } },
                                                                                            y: { display: false }
                                                                                        }
                                                                                    }
                                                                                });
                                                                            </script>
                                                                        }

