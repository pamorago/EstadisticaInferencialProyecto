п»ҝ@model EI.Web.ViewModels.EstadisticasViewModel
@using System.Text.Json
@using System.Globalization
@{
    ViewData["Title"] = "Estadistica Inferencial";
    var inv = CultureInfo.InvariantCulture;
    var jsonOpts = new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
    var pacientesJson = JsonSerializer.Serialize(Model.Pacientes, jsonOpts);
    bool rechaza = Model.RechazaH0;
}

<!-- ГўвҖўВҗГўвҖўВҗ HERO ГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗ -->
<div class="hero-banner mb-4">
    <div class="hero-inner">
        <div>
            <h1 class="hero-title"><i class="bi bi-activity me-2"></i>Estadistica Inferencial</h1>
            <p class="hero-sub">Analisis de pacientes &middot; Base de datos de salud 2026 &middot; Prof. Sandra
                Rodriguez Herrera</p>
            </div>
            <div class="hero-badges">
                <span class="hbadge"><i class="bi bi-people-fill me-1"></i>n = @Model.NTotal pacientes</span>
                <span class="hbadge"><i class="bi bi-gender-male me-1"></i>@Model.NHombres hombres</span>
                <span class="hbadge"><i class="bi bi-gender-female me-1"></i>@Model.NMujeres mujeres</span>
            </div>
        </div>
    </div>

    <!-- ГўвҖўВҗГўвҖўВҗ FORMULARIO DE PARAMETROS ГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗ -->
    <form method="post" id="frmParametros">
        @Html.AntiForgeryToken()
        <div class="param-bar mb-1">
            <div class="param-group">
                <label class="param-label">
                    <i class="bi bi-percent me-1 text-primary"></i>Nivel de confianza (IC)
                </label>
                <div class="slider-row">
                    <input type="range" id="rngConfianza" min="0.800" max="0.999" step="0.001"
                           value="@Model.NivelConfianza.ToString("F3", inv)" class="form-range flex-grow-1"
                           oninput="syncParam('Confianza',this.value)" />
                    <input type="number" id="numConfianza" name="nivelConfianza" min="0.800" max="0.999" step="0.001"
                           value="@Model.NivelConfianza.ToString("F3", inv)" class="param-num-input"
                           oninput="syncParam('Confianza',this.value)" />
                </div>
                <div class="d-flex justify-content-between param-range-labels"><span>80%</span><span>99.9%</span></div>
            </div>
            <div class="param-group">
                <label class="param-label">
                    <i class="bi bi-person-fill me-1 text-warning"></i>IMC poblacional (&mu;&#8320;)
                </label>
                <div class="slider-row">
                    <input type="range" id="rngMedia" min="18" max="40" step="0.1"
                           value="@Model.MediaPoblacionalImc.ToString("F1", inv)" class="form-range flex-grow-1"
                           oninput="syncParam('Media',this.value)" />
                    <input type="number" id="numMedia" name="mediaPoblacionalImc" min="18" max="40" step="0.1"
                           value="@Model.MediaPoblacionalImc.ToString("F1", inv)" class="param-num-input"
                           oninput="syncParam('Media',this.value)" />
                </div>
                <div class="d-flex justify-content-between param-range-labels"><span>18</span><span>40</span></div>
            </div>
            <div class="param-group">
                <label class="param-label">
                    <i class="bi bi-shield-exclamation me-1 text-danger"></i>Significancia (&alpha;)
                </label>
                <div class="slider-row">
                    <input type="range" id="rngAlpha" min="0.001" max="0.200" step="0.001"
                           value="@Model.NivelSignificancia.ToString("F3", inv)" class="form-range flex-grow-1"
                           oninput="syncParam('Alpha',this.value)" />
                    <input type="number" id="numAlpha" name="nivelSignificancia" min="0.001" max="0.200" step="0.001"
                           value="@Model.NivelSignificancia.ToString("F3", inv)" class="param-num-input"
                           oninput="syncParam('Alpha',this.value)" />
                </div>
                <div class="d-flex justify-content-between param-range-labels"><span>0.001</span><span>0.200</span></div>
            </div>
            <div class="param-group d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100 btn-recalcular">
                    <i class="bi bi-calculator-fill me-1"></i>Recalcular
                </button>
            </div>
        </div>
    </form>

    <!-- ГўвҖўВҗГўвҖўВҗ TABS ГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗ -->
    <ul class="nav nav-tabs ei-tabs" id="mainTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tab-a-btn" data-bs-toggle="tab" data-bs-target="#tab-a" type="button"
                    role="tab">
                <i class="bi bi-bar-chart-line-fill me-1"></i>a) Promedios de Pesos
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-b-btn" data-bs-toggle="tab" data-bs-target="#tab-b" type="button" role="tab">
                <i class="bi bi-arrows-expand me-1"></i>b) Intervalo de Confianza
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-c-btn" data-bs-toggle="tab" data-bs-target="#tab-c" type="button" role="tab">
                <i class="bi bi-clipboard2-pulse-fill me-1"></i>c) Prueba de Hipotesis
                @if (rechaza)
                {
                    <span class="badge bg-danger ms-1">H&#8320; Rechazada</span>
                }
                else
                {

                    <span class="badge bg-warning text-dark ms-1">No Rechaza</span>
                }
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-datos-btn" data-bs-toggle="tab" data-bs-target="#tab-datos" type="button"
                    role="tab">
                <i class="bi bi-table me-1"></i>Base de Datos
            </button>
        </li>
    </ul>

    <div class="tab-content ei-tab-content">

        <!-- ГўвҖўВҗГўвҖўВҗ TAB a) PROMEDIOS ГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗ -->
        <div class="tab-pane fade show active" id="tab-a" role="tabpanel">
            <div class="tab-header tab-header-primary">
                <i class="bi bi-bar-chart-line-fill me-2"></i>Promedios de Pesos &mdash; General, Hombres y Mujeres
            </div>
            <div class="tab-body">
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <div class="kpi-card kpi-general">
                            <div class="kpi-icon">&#9878;</div>
                            <div class="kpi-val">@Model.PromedioGeneralPeso.ToString("F2") kg</div>
                            <div class="kpi-lbl">Promedio General</div>
                            <div class="kpi-sub">n = @Model.NTotal</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="kpi-card kpi-hombre">
                            <div class="kpi-icon"><i class="bi bi-gender-male" style="font-size:2rem"></i></div>
                            <div class="kpi-val">@Model.PromedioHombresPeso.ToString("F2") kg</div>
                            <div class="kpi-lbl">Promedio Hombres (x&#773;&#8321;)</div>
                            <div class="kpi-sub">n&#8321; = @Model.NHombres &nbsp;&middot;&nbsp; s&#8321; =
                                @Model.S1Hombres.ToString("F2") kg</div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="kpi-card kpi-mujer">
                                <div class="kpi-icon"><i class="bi bi-gender-female" style="font-size:2rem"></i></div>
                                <div class="kpi-val">@Model.PromedioMujeresPeso.ToString("F2") kg</div>
                                <div class="kpi-lbl">Promedio Mujeres (x&#773;&#8322;)</div>
                                <div class="kpi-sub">n&#8322; = @Model.NMujeres &nbsp;&middot;&nbsp; s&#8322; =
                                    @Model.S2Mujeres.ToString("F2") kg</div>
                                </div>
                            </div>
                        </div>
                        <div class="row g-4">
                            <div class="col-lg-5">
                                <div class="chart-card">
                                    <div class="chart-title"><i class="bi bi-bar-chart-fill me-1"></i>Promedio por Grupo</div>
                                    <canvas id="chartPromedios"></canvas>
                                </div>
                            </div>
                            <div class="col-lg-7">
                                <div class="chart-card">
                                    <div class="chart-title"><i class="bi bi-graph-up-arrow me-1"></i>Distribucion Individual de
                                        Pesos</div>
                                        <canvas id="chartPesos"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ГўвҖўВҗГўвҖўВҗ TAB b) INTERVALO DE CONFIANZA ГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗГўвҖўВҗ -->
                    <div class="tab-pane fade" id="tab-b" role="tabpanel">
                        <div class="tab-header tab-header-primary">
                            <i class="bi bi-arrows-expand me-2"></i>
                            Intervalo de Confianza al @((Model.NivelConfianza * 100).ToString("F1"))% &mdash; Diferencia de Medias de
                            Pesos
                        </div>
                        <div class="tab-body">
                            <div class="formula-box formula-orange mb-4">
                                <div class="formula-title">Formula aplicada (t de Welch &mdash; varianzas desiguales)</div>
                                <p class="formula-text">
                                    IC<sub>@((Model.NivelConfianza*100).ToString("F0"))%</sub>(&mu;&#8321; &minus; &mu;&#8322;)
                                    &nbsp;=&nbsp; (x&#773;&#8321; &minus; x&#773;&#8322;) &plusmn; t<sub>&alpha;/2, &nu;</sub> &middot;
                                    &radic;(s&#8321;&sup2;/n&#8321; + s&#8322;&sup2;/n&#8322;)
                                </p>
                                <p class="formula-sub">
                                    &alpha; = @((1 - Model.NivelConfianza).ToString("F3")) &nbsp;&middot;&nbsp;
                                    &alpha;/2 = @(((1 - Model.NivelConfianza) / 2).ToString("F4")) &nbsp;&middot;&nbsp;
                                    &nu; (Welch&ndash;Satterthwaite) = @Model.GradosLibertad.ToString("F2")
                                </p>
                            </div>

                            <div class="steps-grid mb-4">
                                <div class="step-box">
                                    <div class="step-num">1</div>
                                    <div class="step-body">
                                        <div class="step-title">Diferencia de medias</div>
                                        <div class="step-val">x&#773;&#8321; &minus; x&#773;&#8322; =
                                            @Model.PromedioHombresPeso.ToString("F4") &minus; @Model.PromedioMujeresPeso.ToString("F4")
                                            = <strong>@Model.DiferenciaMedias.ToString("F4") kg</strong></div>
                                        </div>
                                    </div>
                                    <div class="step-box">
                                        <div class="step-num">2</div>
                                        <div class="step-body">
                                            <div class="step-title">Error estandar</div>
                                            <div class="step-val">&radic;(s&#8321;&sup2;/n&#8321; + s&#8322;&sup2;/n&#8322;) =
                                                <strong>@Model.ErrorEstandar.ToString("F4")</strong></div>
                                            </div>
                                        </div>
                                        <div class="step-box">
                                            <div class="step-num">3</div>
                                            <div class="step-body">
                                                <div class="step-title">t critico</div>
                                                <div class="step-val">t<sub>@(((1-Model.NivelConfianza)/2).ToString("F4")),
                                                    @Model.GradosLibertad.ToString("F1")</sub> =
                                                    <strong>@Model.TCritico.ToString("F4")</strong></div>
                                                </div>
                                            </div>
                                            <div class="step-box step-box-orange">
                                                <div class="step-num step-num-orange">&#10003;</div>
                                                <div class="step-body">
                                                    <div class="step-title">Margen de error</div>
                                                    <div class="step-val">@Model.TCritico.ToString("F4") &times; @Model.ErrorEstandar.ToString("F4")
                                                        = <strong>@((Model.TCritico * Model.ErrorEstandar).ToString("F4")) kg</strong></div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="ic-result-box mb-4">
                                                <div class="ic-label-top">Intervalo de Confianza al @((Model.NivelConfianza * 100).ToString("F1"))%
                                                </div>
                                                <div class="ic-values">
                                                    <span class="ic-bracket">[</span>
                                                    <span class="ic-val">@Model.ICLimiteInferior.ToString("F4")</span>
                                                    <span class="ic-sep">,</span>
                                                    <span class="ic-val">@Model.ICLimiteSuperior.ToString("F4")</span>
                                                    <span class="ic-bracket">]</span>
                                                    <span class="ic-unit">kg</span>
                                                </div>
                                            </div>

                                            <div
                                                class="alert @(Model.ICLimiteInferior > 0 || Model.ICLimiteSuperior < 0 ? "alert-danger" : "alert-warning") mb-4">
                                                <i class="bi bi-info-circle-fill me-2"></i>
                                                <strong>Interpretacion:</strong> Con un @((Model.NivelConfianza*100).ToString("F1"))% de confianza,
                                                la diferencia promedio de peso entre hombres y mujeres esta entre
                                                <strong>@Model.ICLimiteInferior.ToString("F4") kg</strong> y
                                                <strong>@Model.ICLimiteSuperior.ToString("F4") kg</strong>.
                                                @if (Model.ICLimiteInferior > 0 || Model.ICLimiteSuperior < 0)
                                                {
                                                    <text>El intervalo <strong>no contiene el cero</strong> &mdash; existe diferencia significativa entre
                                                        grupos.</text>
                                                    }
            else
                                                    {
                                                        <text>El intervalo <strong>contiene el cero</strong> &mdash; no hay diferencia estadisticamente
                                                            significativa.</text>
                                                        }
                                                    </div>

                                                    <div class="chart-card">
                                                        <div class="chart-title"><i class="bi bi-arrows-expand me-1"></i>Visualizacion del Intervalo de
                                                            Confianza</div>
                                                            <canvas id="chartIC" height="110"></canvas>
                                                        </div>
                                                    </div>
                                                </div>

